# FAL.ai Configuration
FAL_KEY="your_fal_api_key_here"

# Linear.dev Configuration  
LINEAR_API_KEY="your_linear_api_key_here"
LINEAR_TEAM_NAME="your_team_name_here"

# DigitalOcean Spaces (S3-compatible)
AWS_S3_ENDPOINT="https://sfo3.digitaloceanspaces.com"
AWS_S3_BUCKET="your_bucket_name"
AWS_ACCESS_KEY_ID="your_do_access_key"
AWS_SECRET_ACCESS_KEY="your_do_secret_key"
AWS_REGION="sfo3"

# Scheduling (optional - for cron)
CRON_SCHEDULE="0 1 * * *"
TIMEZONE="UTC"

# Linear team to track (optional - defaults to "Pintask")
LINEAR_TEAM_NAME="Pintask"
